{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "builds": [
    {
      "src": "api/auth.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/account.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/payments.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/launcher.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/download/artifact.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/loader_compat.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/bind_hwid_compat.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/loader.php",
      "destination": "/api/loader_compat.js"
    },
    {
      "source": "/api/bind_hwid.php",
      "destination": "/api/bind_hwid_compat.js"
    },
    {
      "source": "/api/admin/bind_hwid.php",
      "destination": "/api/bind_hwid_compat.js"
    },
    {
      "source": "/api/auth/login",
      "destination": "/api/auth.js"
    },
    {
      "source": "/api/auth/refresh",
      "destination": "/api/auth.js"
    },
    {
      "source": "/api/account/me",
      "destination": "/api/account.js"
    },
    {
      "source": "/api/account/download/launcher-url",
      "destination": "/api/account.js"
    },
    {
      "source": "/api/payments/create",
      "destination": "/api/payments.js"
    },
    {
      "source": "/api/payments/check",
      "destination": "/api/payments.js"
    },
    {
      "source": "/api/payments/webhook",
      "destination": "/api/payments.js"
    },
    {
      "source": "/api/launcher/login",
      "destination": "/api/launcher.js"
    },
    {
      "source": "/api/launcher/manifest",
      "destination": "/api/launcher.js"
    },
    {
      "source": "/api/launcher/heartbeat",
      "destination": "/api/launcher.js"
    },
    {
      "source": "/api/launcher/verify-session",
      "destination": "/api/launcher.js"
    },
    {
      "source": "/api/download/artifact",
      "destination": "/api/download/artifact.js"
    },
    {
      "source": "/downloads/(.*)",
      "destination": "/api/download/artifact.js?type=$1"
    },
    {
      "source": "/offer",
      "destination": "/index.html"
    },
    {
      "source": "/privacy",
      "destination": "/index.html"
    },
    {
      "source": "/contacts",
      "destination": "/index.html"
    },
    {
      "source": "/((?!api|downloads|offer|privacy|contacts).*)",
      "destination": "/index.html"
    }
  ]
}
