{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    },
    {
      "source": "/artifacts/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "application/java-archive" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "functions": {
    "api/**/*.js": {
      "includeFiles": "artifacts/**"
    }
  },
  "rewrites": [
    { "source": "/api/loader.php", "destination": "/api/loader_compat.js" },
    { "source": "/api/bind_hwid.php", "destination": "/api/bind_hwid_compat.js" },
    { "source": "/api/auth/login", "destination": "/api/auth.js" },
    { "source": "/api/auth/refresh", "destination": "/api/auth.js" },
    { "source": "/api/account/me", "destination": "/api/account.js" },
    { "source": "/api/account/hwid-reset", "destination": "/api/account.js" },
    { "source": "/api/payments/create", "destination": "/api/payments.js" },
    { "source": "/api/payments/check", "destination": "/api/payments.js" },
    { "source": "/api/payments/webhook", "destination": "/api/payments.js" },
    { "source": "/api/launcher/:path*", "destination": "/api/launcher.js" },
    { "source": "/api/client/:path*", "destination": "/api/client.js" },
    { "source": "/api/download/artifact", "destination": "/api/download-artifact.js" },
    { "source": "/downloads/(.*)", "destination": "/api/download-artifact.js?type=$1" },
    { "source": "/offer", "destination": "/index.html" },
    { "source": "/privacy", "destination": "/index.html" },
    { "source": "/contacts", "destination": "/index.html" },
    { "source": "/((?!api|downloads|offer|privacy|contacts).*)", "destination": "/index.html" }
  ]
}
