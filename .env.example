# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# -------------------------------------------------------------------
# Aura license backend (Vercel + Firebase RTDB)
# -------------------------------------------------------------------
FIREBASE_API_KEY=""
FIREBASE_AUTH_DOMAIN=""
FIREBASE_PROJECT_ID=""
FIREBASE_STORAGE_BUCKET=""
FIREBASE_MESSAGING_SENDER_ID=""
FIREBASE_APP_ID=""
FIREBASE_DATABASE_URL=""
FIREBASE_WEB_API_KEY=""

# PEM private key for /api/launcher/manifest signing (Ed25519)
# Keep as one line with \n in Vercel env vars.
MANIFEST_PRIVATE_KEY_PEM=""

# Optional static artifact info (if set, file hashing on server is skipped)
CLIENT_VERSION="1.16.5-20260329"
CLIENT_DOWNLOAD_URL="https://your-domain.com/downloads/AuraClient.jar"
CLIENT_SHA256="fdd461b8038180b4d47221f934a6721e49ad92fae5d2816f87774ecf4b3e928f"
CLIENT_SIZE="32923310"
CLIENT_JAR_PATH="public/downloads/AuraClient.jar"

# Session and rate limits
SESSION_TTL_MS="86400000"
MANIFEST_TTL_MS="60000"
DOWNLOAD_LINK_TTL_MS="300000"
FREE_HWID_RESETS_PER_WINDOW="1"
HWID_RESET_WINDOW_MS="2592000000"
LAUNCHER_LOGIN_RATE_LIMIT="12"
LAUNCHER_LOGIN_WINDOW_MS="600000"
LAUNCHER_VERIFY_RATE_LIMIT="120"
LAUNCHER_VERIFY_WINDOW_MS="600000"
LAUNCHER_MANIFEST_RATE_LIMIT="120"
LAUNCHER_MANIFEST_WINDOW_MS="600000"
PAYMENTS_CREATE_RATE_LIMIT="30"
PAYMENTS_CREATE_WINDOW_MS="600000"
SECURITY_EVENT_RATE_LIMIT="120"
SECURITY_EVENT_WINDOW_MS="600000"

# Payments
PAYMENT_WEBHOOK_SECRET=""
YOOKASSA_SHOP_ID=""
YOOKASSA_SECRET_KEY=""
YOOKASSA_WEBHOOK_SECRET=""
YOOKASSA_API_URL="https://api.yookassa.ru/v3"

# Download links and artifact storage
APP_URL="https://your-domain.com"
DOWNLOAD_LINK_SECRET=""
CLIENT_ARTIFACT_PATH="public/downloads/AuraClient.jar"
CLIENT_ARTIFACT_NAME="AuraClient.jar"
CLIENT_ARTIFACT_CONTENT_TYPE="application/java-archive"
LAUNCHER_ARTIFACT_PATH="artifacts/AuraLauncher.exe"
LAUNCHER_ARTIFACT_NAME="AuraLauncher.exe"
LAUNCHER_ARTIFACT_CONTENT_TYPE="application/vnd.microsoft.portable-executable"
LAUNCHER_VERSION="mega-webview-x64-20260329"
LAUNCHER_SHA256="79acf4084f7665c87ee91389c1d9773b2e80d67f963dd3441d9836c9e8226ccb"
LAUNCHER_SIZE="534528"

# Manifest key rotation (optional key-ring)
MANIFEST_CURRENT_KID="v1"
MANIFEST_PRIVATE_KEYS_JSON="{\"current\":\"v1\",\"keys\":{\"v1\":\"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\"}}"

# Admin API
ADMIN_API_SECRET=""

# Frontend Vite Firebase envs
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_DATABASE_URL=""
